{
  "name": "Ubuntu Desktop Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Ubuntu Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "vscode",
  "postStartCommand": "/usr/local/bin/create-vnc-password.sh && sudo service supervisor start"
}
